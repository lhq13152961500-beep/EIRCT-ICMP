# =============================================
# 乡音伴路 App - 环境变量配置示例
# 复制此文件为 .env 并填入你自己的值
# =============================================

# PostgreSQL 数据库连接字符串
# 推荐免费服务：Neon (neon.tech)、Supabase (supabase.com)、Railway (railway.app)
# 格式：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://username:password@host:5432/dbname

# 高德地图 API Key（Web端JS API）
# 申请地址：https://console.amap.com/dev/key/app
# 平台类型选择：Web端(JS API)
AMAP_API_KEY=your_amap_js_api_key_here

# 高德地图 API Key（Web服务）
# 同上地址申请，平台类型选择：Web服务
AMAP_SERVER_KEY=your_amap_server_key_here

# 高德地图安全密钥（可选，开启安全加固时需要）
AMAP_SECURITY_KEY=your_amap_security_key_here

# 服务端口（默认 5000）
PORT=5000

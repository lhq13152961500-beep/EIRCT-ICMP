{
  "expo": {
    "name": "乡音伴旅v1.0",
    "slug": "v10",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "v10",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3DAA6F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.v10.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "录制声音日记和语音留言需要使用麦克风",
        "NSLocationWhenInUseUsageDescription": "关联地标和发布录音需要获取您的位置信息",
        "NSCameraUsageDescription": "AR实景畅游功能需要使用摄像头识别建筑物",
        "NSMotionUsageDescription": "自适应漫游步态分析功能需要读取运动与步数数据"
      }
    },
    "android": {
      "package": "com.v10.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#3DAA6F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "f933097e-2f32-4341-a375-e5d6016787a8"
      }
    },
    "owner": "blacktoo"
  }
}
